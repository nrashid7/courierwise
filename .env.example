# Copy to .env and fill in real values for local dev.
# In Lovable Cloud these are injected automatically — you do not need a local .env.

# Server (do not expose to the client)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PASSPHRASE=

# Client (safe to expose — bundled at build time)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
